# ── Database ─────────────────────────────────────────────
# Local dev: the Postgres container in docker-compose.yml
# Production: replace with your managed Postgres (Neon/Supabase/RDS) URL
DATABASE_URI=postgres://jv:jv_dev_password@localhost:5439/jv_ventures

# ── Payload ──────────────────────────────────────────────
PAYLOAD_SECRET=replace_with_a_long_random_string

# ── Public site ──────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Object storage (optional in dev) ─────────────────────
# Set these for Cloudflare R2 / AWS S3 to store media in a bucket.
# Leave blank to use local disk (./media) during development.
# S3_BUCKET=
# S3_ENDPOINT=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
